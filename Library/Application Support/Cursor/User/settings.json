{
  /* ウインドウ・起動 */
  "window.title": "${activeRepositoryName} ${separator} ${activeEditorMedium} ${dirty}", // ウインドウタイトルにリポジトリ名とファイルパスを表示する
  "window.openFoldersInNewWindow": "on", // 新規ワークスペースを別ウインドウで開く
  "window.zoomLevel": 2, // ウインドウのズームレベルを2倍にする
  "workbench.startupEditor": "none", // 起動時にウェルカムページを表示しない
  "security.workspace.trust.untrustedFiles": "open", // 信頼されていないファイルを確認なしで開く
  "security.promptForLocalFileProtocolHandling": false, // ローカルファイルプロトコルの確認プロンプトを表示しない

  /* Cursor */
  "update.showReleaseNotes": false, // リリースノートを表示しない
  "cursor.terminal.usePreviewBox": true, // ターミナルでプレビューボックスを使用する
  "cursor.composer.shouldChimeAfterChatFinishes": true, // チャット終了後に通知音を鳴らす
  "cursor.windowSwitcher.sidebarHoverCollapsed": true, // サイドバーが折りたたまれた状態でウィンドウスイッチャーのホバー表示を有効にする

  /* ワークベンチ - テーマ・外観 */
  "workbench.colorTheme": "Ayu Dark Bordered", // カラーテーマにAyu Dark Borderedを使用する
  "workbench.iconTheme": "vscode-icons", // アイコンテーマにvscode-iconsを使用する
  "workbench.activityBar.orientation": "vertical", // アクティビティバーを垂直に表示する
  "workbench.colorCustomizations": {
    // カーソル行のハイライト色をカスタマイズする
    "editor.lineHighlightBackground": "#1073cf2d",
    "editor.lineHighlightBorder": "#9fced11f"
  },

  /* ワークベンチ - タブ・レイアウト */
  "workbench.editor.enablePreview": false, // プレビュータブを無効化（常に新しいタブで開く）
  "workbench.editor.pinnedTabsOnSeparateRow": true, // ピン留めしたタブを別の行に表示する
  "workbench.editor.labelFormat": "short", // タブにファイル名のみを短く表示する
  "workbench.editor.tabSizing": "fixed", // タブのサイズを固定する
  "workbench.list.smoothScrolling": true, // サイドバー等のリストでスムーズスクロールを有効にする

  /* エクスプローラー */
  "workspaceExplorer.workspaceStorageDirectory": "/Users/alpaca1231/dev/workspace", // ワークスペースの設定ファイルを指定パスに保存する
  "explorer.confirmDelete": false, // ファイル削除時の確認を表示しない
  "explorer.confirmDragAndDrop": false, // ファイルのドラッグ＆ドロップ時の確認を表示しない
  "explorer.compactFolders": false, // フォルダーを圧縮しない
  "explorer.fileNesting.enabled": true, // 関連ファイルをネストして表示する
  "explorer.fileNesting.expand": false, // ネストされたファイルをデフォルトで折りたたむ

  /* エディター - フォント・表示 */
  "editor.fontSize": 14, // フォントサイズを14pxにする
  "editor.fontFamily": "HackGen35, monospace", // フォントにHackGen35を使用する
  "editor.mouseWheelZoom": true, // Ctrl+マウスホイールでエディターをズームする
  "editor.tabSize": 2, // タブ幅を2スペースにする
  "editor.renderControlCharacters": true, // 制御文字を表示する
  "editor.renderWhitespace": "boundary", // 行頭・行末の空白のみ表示する
  "editor.renderLineHighlight": "all", // カーソル行を行番号含めすべてハイライトする
  "editor.guides.indentation": false, // インデントガイドを表示しない
  "editor.guides.bracketPairs": "active", // アクティブな括弧ペアのガイドを表示する
  "editor.unicodeHighlight.nonBasicASCII": false, // 非ASCII文字をハイライトしない
  "editor.accessibilitySupport": "off", // アクセシビリティサポートを無効にする

  /* エディター - 操作・補完 */
  "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>/?", // ハイフンを単語区切りから除外してケバブケースを一括選択可能にする
  "editor.snippetSuggestions": "top", // スニペットの候補を上部に表示する
  "editor.inlayHints.enabled": "onUnlessPressed", // インレイヒントを表示（Ctrl押下で非表示）
  "editor.suggest.insertMode": "replace", // サジェスト選択時に既存テキストを置換する
  "editor.linkedEditing": true, // HTMLタグの連動編集を有効にする
  "editor.foldingImportsByDefault": true, // ファイルを開いたときにインポートを折りたたむ
  "editor.stickyScroll.enabled": true, // スコープのヘッダーを画面上部に固定表示する

  /* エディター - 保存・フォーマット */
  "editor.formatOnSave": true, // 保存時にフォーマットする
  "editor.defaultFormatter": "esbenp.prettier-vscode", // デフォルトのフォーマッターとしてPrettierを使用する
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit", // importの整理（並び替え・未使用削除）
    "source.addMissingImports": "explicit", // 必要なimportを追加
    "source.fixAll": "explicit" // fixを実行
  },

  /* エディター - スクロール・アニメーション */
  "editor.smoothScrolling": true, // スムーズスクロールを有効にする
  "editor.cursorSmoothCaretAnimation": "on", // カーソル移動をスムーズにアニメーションする

  /* エディター - ミニマップ */
  "editor.minimap.renderCharacters": false, // ミニマップを文字ではなくブロックで表示する
  "editor.minimap.size": "fit", // ミニマップのサイズをエディターの高さに合わせる
  "editor.minimap.maxColumn": 50, // ミニマップの最大幅を50列にする
  "editor.minimap.showSlider": "always", // ミニマップでスライダーを常に表示する

  /* ターミナル */
  "terminal.integrated.fontFamily": "'HackGen35 Console NF', monospace", // ターミナルのフォントにHackGen35 Console NFを使用する
  "terminal.external.osxExec": "Ghostty.app", // 外部ターミナルとしてGhosttyを使用する
  "terminal.integrated.smoothScrolling": true, // ターミナルのスムーズスクロールを有効にする

  /* ファイル */
  "files.autoSave": "onFocusChange", // エディターのフォーカスが外れたときに自動保存する
  "files.hotExit": "onExitAndWindowClose", // アプリ終了・ウインドウクローズ時に未保存ファイルを記憶する
  "files.trimTrailingWhitespace": true, // 行末の不要な空白を自動削除する
  "files.defaultLanguage": "markdown", // 新規ファイルのデフォルト言語をMarkdownにする
  "files.insertFinalNewline": true, // ファイルの保存時に末尾に改行を挿入する
  "files.trimFinalNewlines": true, // ファイルの保存時に最終行以降をトリミングする
  "files.watcherExclude": {
    // ファイル監視から指定パターンを除外する
    "**/node_modules/**": true
  },

  /* 差分エディター */
  "diffEditor.ignoreTrimWhitespace": true, // 差分エディタで先頭・末尾の空白変更を無視する

  /* Emmet */
  "emmet.showSuggestionsAsSnippets": true, // Emmetの候補をスニペットとして表示する
  "emmet.triggerExpansionOnTab": true, // TABキーでEmmetを展開できるようにする
  "emmet.variables": {
    "lang": "ja" // Emmetで展開されるHTMLの言語を日本語にする
  },

  /* Markdown */
  "[markdown]": {
    "files.trimTrailingWhitespace": false, // 行末の空白をトリミングしない
    "editor.formatOnSave": false // 保存時にフォーマットしない
  },

  /* JavaScript / TypeScript */
  "javascript.updateImportsOnFileMove.enabled": "always", // ファイル移動時にインポートを更新する
  "javascript.suggest.completeFunctionCalls": true, // 関数呼び出しの引数を補完する
  "javascript.suggest.completeJSDocs": true, // JSDocコメントを補完する
  "javascript.referencesCodeLens.enabled": true, // 参照数を表示する
  "typescript.updateImportsOnFileMove.enabled": "always", // ファイル移動時にインポートを更新する
  "typescript.suggest.completeFunctionCalls": true, // 関数呼び出しの引数を補完する
  "typescript.suggest.completeJSDocs": true, // JSDocコメントを補完する
  "typescript.referencesCodeLens.enabled": true, // 参照数を表示する
  "typescript.inlayHints.enumMemberValues.enabled": true, // enum値をコード内に表示する
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true, // 関数の戻り値の型をコード内に表示する
  "typescript.inlayHints.parameterNames.enabled": "all", // パラメータ名をコード内に表示する
  "typescript.inlayHints.parameterTypes.enabled": true, // パラメータの型をコード内に表示する
  "typescript.preferences.importModuleSpecifier": "non-relative", // インポートパスに非相対パスを使用する

  /* 検索 */
  "search.exclude": {
    // 検索から指定パターンを除外する
    "*.lock": true,
    "**/node_modules/**": true,
    "**/tmp": true,
    "*lock.json": true
  },
  "search.smartCase": true, // 小文字のみなら大文字小文字を区別しない

  /* Git / GitHub */
  "git.confirmSync": false, // Gitの同期時の確認を表示しない
  "git.ignoreMissingGitWarning": true, // Gitがない場合の警告を無視する
  "git.autofetch": true, // リモートの変更を自動的にフェッチする

  /* 拡張機能 - Indent Rainbow */
  "indentRainbow.colors": [
    // インデントレベルごとに色分けする
    "rgba(128, 64, 64, 0.5)",
    "rgba(128, 96, 32, 0.5)",
    "rgba(128, 128, 32, 0.5)",
    "rgba(32, 128, 32, 0.5)",
    "rgba(32, 64, 128, 0.5)",
    "rgba(128, 64, 128, 0.5)"
  ],

  /* 拡張機能 - VSCode Icons */
  "vsicons.dontShowNewVersionMessage": true, // 新バージョン通知を表示しない

  /* 拡張機能 - Template String Converter */
  "template-string-converter.addBracketsToProps": true, // JSXのテンプレート文字列に{}を追加する
  "template-string-converter.convertOutermostQuotes": true, // ネストされた引用符の場合は最も外側のクォーテーションを変換する
  "template-string-converter.autoRemoveTemplateString": true, // ${}を削除したときにテンプレート文字列を自動的に削除する

  /* 拡張機能 - Turbo Console Log */
  "turboConsoleLog.logMessagePrefix": "💻", // ログメッセージのプレフィックスを💻にする
  "turboConsoleLog.delimiterInsideMessage": "|", // ログメッセージの区切り文字を「|」にする
  "turboConsoleLog.logMessageSuffix": ":", // ログメッセージのサフィックスを「:」にする
  "turboConsoleLog.insertEnclosingClass": false, // ログにクラス名を含めない
  "turboConsoleLog.insertEnclosingFunction": false, // ログに関数名を含めない

  /* 拡張機能 - TODO Highlight */
  "todo.embedded.regex": "(?:<!-- *)?(?:#|// @|//|/\\*+|<!--|--|\\* @|\\{!|\\{\\{!--|\\{\\{!) *(TODO|FIXME|MEMO|BUG|UGLY|HACK|NOTE|IDEA|REVIEW|DEBUG|OPTIMIZE)(?:\\s*\\([^)]+\\))?:?(?!\\w)(?: *-->| *\\*/| *!}| *--}}| *}}|(?= *(?:[^:]//|/\\*+|<!--|@|--|\\{!|\\{\\{!--|\\{\\{!))|((?: +[^\\n@]*?)(?= *(?:[^:]//|/\\*+|<!--|@|--(?!>)|\\{!|\\{\\{!--|\\{\\{!))|(?: +[^@\\n]+)?))", // TODO/FIXME等のコメントをカスタムパターンで検出する

  /* 拡張機能 - Error Lens */
  "errorLens.enabledDiagnosticLevels": ["error", "warning"] // エラーと警告のみを表示する

  /* EOL */
}
