{
  "Print to console": {
    "prefix": "cl",
    "body": ["console.log($1);", "$2"],
    "description": "Log output to console"
  },
  "className": {
    "prefix": "cn",
    "body": ["className='$1'"],
    "description": "className"
  },
  "React component": {
    "prefix": "rc",
    "body": [
      "type Props = {",
      "  $1",
      "};",
      "",
      "export const ${TM_FILENAME_BASE/^(\\w)(.*)/${1:/capitalize}${2}/} = ({ $2 }: Props) => {",
      "  return (",
      "    <>",
      "      $3",
      "    </>",
      "  );",
      "};",
      ""
    ]
  },
  "React component tailwindcss shadcn/ui": {
    "prefix": "rtw",
    "body": [
      "import { cn } from '@/lib/utils';",
      "",
      "type Props = {",
      "  $1",
      "  className?: string;",
      "};",
      "",
      "export const ${TM_FILENAME_BASE/^(\\w)(.*)/${1:/capitalize}${2}/} = ({ $2className }: Props) => {",
      "  return (",
      "    <div className={cn('$3', className)}>",
      "      $4",
      "    </div>",
      "  );",
      "};",
      ""
    ]
  }
}
