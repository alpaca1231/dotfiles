# =============================================================================
# ユーザー・コミット署名（1Password SSH）
# =============================================================================
[user]
	name = {{ .name }}
	email = {{ .email }}
	# SSH 署名用公開鍵（1Password）
	signingkey = {{ onepasswordRead "op://ucpfli3yejoywdg4u3y6mscgt4/ibcftwvlo5c55z3zacnob32t2q/public_key" }}

[gpg]
	format = ssh

[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

# =============================================================================
# リポジトリ初期化・エディタ
# =============================================================================
[init]
	defaultBranch = main

[core]
	editor = nvim
	ignorecase = false

# =============================================================================
# コミット・タグ（署名）
# =============================================================================
[commit]
	gpgsign = true
	verbose = true

[tag]
	gpgsign = true

# =============================================================================
# fetch / pull / rebase
# =============================================================================
[fetch]
	prune = true

[pull]
	ff = only
	autostash = true

[rebase]
	autostash = true

# =============================================================================
# マージ・コンフリクト
# =============================================================================
[merge]
	conflictstyle = diff3

[rerere]
	enabled = true

# =============================================================================
# ツール連携
# =============================================================================
[ghq]
	root = ~/dev

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

# =============================================================================
# URL 書き換え（HTTPS → SSH）
# =============================================================================
[url "ssh://git@github.com/"]
	insteadOf = https://github.com/
